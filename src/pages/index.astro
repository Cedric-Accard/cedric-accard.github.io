---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import bibFileRaw from '../data/publications.bib?raw';
import { url } from '../utils/paths';

import { getCollection } from 'astro:content';

const conferences = (await getCollection('conferences')).sort(
    (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
).slice(0, 3);

interface Author {
	first: string;
	last: string;
}

interface BibEntry {
	type: string;
	key: string;
	fields: Record<string, string>;
	authors: Author[];
}

function parseBibTeX(input: string): BibEntry[] {
    const entries: BibEntry[] = [];
    const rawEntries = input.split(/@(\w+)\s*\{/g).slice(1);

    for (let i = 0; i < rawEntries.length; i += 2) {
        const type = rawEntries[i].trim();
        const body = rawEntries[i+1];
        if (!body) continue;

        const keyMatch = body.match(/^\s*([^,]+),/);
        const key = keyMatch ? keyMatch[1].trim() : 'unknown';
        
        const fields: Record<string, string> = { title: "Untitled", year: "0000" };
        const fieldRegex = /(\w+)\s*=\s*(?:\{((?:[^{}]|{[^{}]*})*)\}|"((?:[^"]|\\")*)"|(\d+))/g;
        
        let match;
        while ((match = fieldRegex.exec(body)) !== null) {
            const fieldKey = match[1].toLowerCase();
            const val = match[2] || match[3] || match[4] || "";
            fields[fieldKey] = val.replace(/\s+/g, ' ').trim();
        }

        let authors: Author[] = [];
        if (fields.author) {
            authors = fields.author.split(/\s+and\s+/i).map(str => {
                const parts = str.split(',');
                if (parts.length > 1) {
                    return { first: parts[1].trim(), last: parts[0].trim() };
                } else {
                    const names = str.trim().split(' ');
                    const last = names.pop() || "";
                    const first = names.join(' ');
                    return { first, last };
                }
            });
        }
        entries.push({ type, key, fields, authors });
    }
    return entries;
}

/*
const publications = parseBibTeX(bibFileRaw).sort((a, b) => {
    return (parseInt(b.fields.year) || 0) - (parseInt(a.fields.year) || 0);
}).slice(0, 3);
*/

const publications = parseBibTeX(bibFileRaw)
    .filter(pub => {
        const first = pub.authors[0];
        return first && first.last.toLowerCase() === 'accard';
    })
    .sort((a, b) => (parseInt(b.fields.year) || 0) - (parseInt(a.fields.year) || 0));
    .slice(0, 3);

const formatAuthor = (auth: Author) => {
    return auth.first ? `${auth.first} ${auth.last}` : auth.last;
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				display: flex;
				align-items: center;
				gap: 4rem;
				padding: 4rem 0;
				margin-bottom: 2rem;
			}
			.hero-content { flex: 3; }
			.hero-image { 
				flex: 2; 
				text-align: center;
                position: relative;
			}
			.hero-image img {
				width: 280px;
				height: 280px;
				object-fit: cover;
				border-radius: 50%;
				border: 6px solid var(--color-bg);
				box-shadow: 0 0 0 1px var(--color-border), var(--shadow-lg);
			}
            
            .pub-mini-item {
                margin-bottom: 1.5rem;
                padding-bottom: 1.5rem;
                border-bottom: 1px solid var(--color-border);
            }
            .pub-mini-item:last-child { border-bottom: none; margin-bottom: 0; }
            .pub-title { font-weight: 700; color: var(--color-text-main); display: block; margin-bottom: 0.25rem; font-family: var(--font-serif); font-size: 1.1rem; }
            .pub-meta { font-size: 0.9rem; color: var(--color-text-muted); }

			.hero-buttons {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
			}
			@media (max-width: 768px) {
				.hero { flex-direction: column-reverse; text-align: center; padding: 2rem 0; gap: 2rem; }
                .hero-image img { width: 200px; height: 200px; }
                .hero-buttons { justify-content: center; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-content">
					<h1 style="margin-bottom: 0.5rem; font-size: 3rem;">Cedric Accard</h1>
					<h2 style="font-weight: 400; color: var(--color-text-muted); margin-bottom: 1.5rem; font-family: var(--font-sans); text-transform: uppercase; letter-spacing: 0.05em; font-size: 1rem; border-bottom: none; padding-bottom: 0; display: block; margin-top: 0;">
						3rd year PhD Student in Astrophysics<br/>
					</h2>
					<div style="font-size: 1.1rem; line-height: 1.7; margin-bottom: 2rem;">
				        <p> I am a 3rd year PhD student in Astrophysics at the <strong>Observatoire Astronomique de Strasbourg</strong> (University of Strasbourg, France), under the supervision of <strong>Florent Renaud</strong>. I hold a Master's degree in Astrophysics and Data Science from Universite de Strasbourg </p>
                        <p> My research focuses on the <strong>evolution of galaxies and star formation across cosmic time</strong>, with a particular emphasis on the <strong>first two billion years of the Universe</strong>.  I study the relations between star formation activity and the physical properties of high-redshift galaxies, combining observational data with state-of-the-art cosmological simulations. I also use codes to model the spectral energy distributions of galaxies wether they are observed, using the SED fitting code <strong>CIGALE</strong>, or simulated using the radiative transfer code <strong>SKIRT</strong>.</p>
                        <p> Outside of research, you will likely find me at the cinema, deep into a music listening moment, or riding my bike somewhere in the mountains. </p>
					</div>
                    <div class="hero-buttons">
						<a href={url('/publications')} class="btn">View Publications</a>
						<a href={url('/projects')} class="btn btn-outline">Current Projects</a>
					</div>
				</div>
				<div class="hero-image">
					<Image src={url('/CA.jpg')} width={280} height={280} alt="Professor Portrait" fetchpriority="high" decoding="async" />
				</div>
			</section>

			<hr style="margin: 3rem 0; border-top: 1px solid var(--color-border);" />

			<div class="grid-2" style="gap: 4rem; margin-top: 0;">
                <section>
                    <h2 style="margin-top: 0;">Selected Publications</h2>
                    <div class="publication-list">
                        {publications.length > 0 ? publications.map((pub) => (
                            <div class="pub-mini-item">
                                <span class="pub-title">{pub.fields.title.replace(/[{}]/g, '')}</span>
                                <div class="pub-meta">
                                    {pub.authors.map(a => formatAuthor(a)).join(', ')}
                                    <br/>
                                    <span style="font-style: italic; color: var(--color-accent);">
                                        {(pub.fields.journal || pub.fields.booktitle || pub.fields.publisher || "Preprint").replace(/[{}]/g, '')}
                                    </span>
                                    {pub.fields.year && <span>, {pub.fields.year}</span>}
                                </div>
                            </div>
                        )) : <p>No publications found.</p>}
                    </div>
                    <div style="margin-top: 1.5rem;">
                        <a href={url('/publications')} style="font-weight: 600;">View Full List &rarr;</a>
                    </div>
                </section>

                <section>
                    <h2 style="margin-top: 0;">Latest Conferences & Talks</h2>
                    <ul style="list-style: none; padding: 0;">
                        {conferences.map((conf) => (
                            <li style="margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px dashed var(--color-border);">
                                <span style="display: block; font-family: var(--font-serif); font-size: 1.1rem; font-weight: 600; color: var(--color-text-main); margin-bottom: 0.25rem;">
                                    {conf.data.title}
                                </span>
                                <small style="color: var(--color-text-muted); font-size: 0.85rem;">
                                    <em>{conf.data.event}</em> — {conf.data.location}<br/>
                                    <span style="text-transform: uppercase; font-size: 0.8rem;">{conf.data.type} · {conf.data.date}</span>
                                </small>
                            </li>
                        ))}
                    </ul>
                    <div style="margin-top: 1.5rem;">
                        <a href={url('/conferences')} style="font-weight: 600;">View All &rarr;</a>
                    </div>
                </section>
            </div>
		</main>
		<Footer />
	</body>
</html>
