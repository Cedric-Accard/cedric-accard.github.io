---
const today = new Date();
import { SITE_TITLE, FOOTER_CREDIT } from '../consts';
---

<footer class="site-footer">
  <div class="footer-credit">
    &copy; {today.getFullYear()} {SITE_TITLE}.
    Designed &amp; created by
    <a href={FOOTER_CREDIT.designerUrl} target="_blank" rel="noopener noreferrer">
      {FOOTER_CREDIT.designerName}
    </a>
  </div>
</footer>